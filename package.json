{
  "name": "vscode-vim-guide",
  "displayName": "Vim Guide",
  "description": "Searchable Vim command and productivity guide for VSCodeVim users.",
  "version": "0.0.1",
  "publisher": "localdev",
  "private": true,
  "engines": {
    "vscode": "^1.91.0"
  },
  "extensionKind": [
    "ui"
  ],
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onView:vimGuide.sidebar",
    "onCommand:vimGuide.open",
    "onCommand:vimGuide.openPanel",
    "onCommand:vimGuide.search",
    "onCommand:vimGuide.refresh"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vimGuide.open",
        "title": "Vim Guide: Open"
      },
      {
        "command": "vimGuide.openPanel",
        "title": "Vim Guide: Open Practice Panel"
      },
      {
        "command": "vimGuide.search",
        "title": "Vim Guide: Search Commands"
      },
      {
        "command": "vimGuide.refresh",
        "title": "Vim Guide: Refresh"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vimGuide",
          "title": "Vim Guide",
          "icon": "resources/vim-guide.svg"
        }
      ]
    },
    "views": {
      "vimGuide": [
        {
          "id": "vimGuide.sidebar",
          "name": "Vim Guide",
          "type": "webview"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "vimGuide.gettingStarted",
        "title": "Get Started with Vim Guide",
        "description": "Learn VSCodeVim through small daily lessons, searchable commands, and read-only VSCodeVim setting checks.",
        "steps": [
          {
            "id": "vimGuide.openSidebar",
            "title": "Open the Vim Guide sidebar",
            "description": "Use the Activity Bar view when you want a compact lesson queue next to your files.",
            "completionEvents": [
              "onCommand:vimGuide.open"
            ]
          },
          {
            "id": "vimGuide.openPanel",
            "title": "Open the practice panel",
            "description": "Use the practice panel when you want a wider lesson and reference view beside your editor.",
            "completionEvents": [
              "onCommand:vimGuide.openPanel"
            ]
          },
          {
            "id": "vimGuide.searchCommands",
            "title": "Search commands from the Command Palette",
            "description": "Run Vim Guide: Search Commands to find a Vim key or VS Code integration command without opening the sidebar.",
            "completionEvents": [
              "onCommand:vimGuide.search"
            ]
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "npm run compile && node ./out/test/runTest.js",
    "verify": "npm run compile && npm run lint && npm test && npm run package",
    "package": "vsce package --no-dependencies --out dist/vscode-vim-guide-0.0.1.vsix",
    "install:local": "code --install-extension dist/vscode-vim-guide-0.0.1.vsix --force"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.2",
    "@types/vscode": "^1.91.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.6.0",
    "eslint": "^8.57.1",
    "mocha": "^10.8.2",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "serialize-javascript": "^7.0.6"
  }
}
